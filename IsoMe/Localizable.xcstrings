    "Visit monitoring tracks places you visit. Significant location changes provides a trail between visits." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتتبع مراقبة الزيارات الأماكن التي تزورها. تتبع التغييرات المهمة في الموقع يوفر مسار بين الزيارات."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "পরিদর্শন মনিটরিং আপনি যে স্থানগুলি পরিদর্শন করেন তা ট্র্যাক করে। উল্লেখযোগ্য অবস্থান পরিবর্তন পরিদর্শনগুলির মধ্যে একটি ট্রেইল সরবরাহ করে।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Visit monitoring tracks places you visit. Significant location changes provides a trail between visits."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El monitoreo de visitas registra los lugares que visitas. Los cambios significativos de ubicación proporcionan un rastro entre visitas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La surveillance des visites enregistre les lieux visités. Les changements de localisation importants fournissent une trace entre les visites."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "विजिट निगरानी आपके द्वारा देखे गए स्थानों को ट्रैक करती है। महत्वपूर्ण स्थान परिवर्तन विजिट के बीच एक पथ प्रदान करते हैं।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "訪問監視は訪問した場所を追跡します。重要な位置変更は訪問間の履跡を提供します。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O monitoramento de visitas rastreia os locais que você visita. Mudanças significativas de localização fornecem um rastro entre visitas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Мониторинг посещений отслеживает места, которые вы посещаете. Значительные изменения местоположения отслеживают маршрут между посещениями."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "访问监测跟踪您访问的地点。重大位置变化提供访问间的足迹。"
          }
        }
      }
    },
    "Visit monitoring tracks places you visit. Significant location changes provides a trail between visits. Location names are looked up when available." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تتبّع مراقبة الزيارات الأماكن التي تزورها. توفّر التغييرات الكبيرة في الموقع مساراً بين الزيارات. يتم البحث عن أسماء الأماكن عند توفرها."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ভিজিট মনিটরিং আপনার দেখা স্থানগুলি ট্র্যাক করে। উল্লেখযোগ্য অবস্থান পরিবর্তন ভিজিটের মধ্যে একটি ট্রেইল প্রদান করে। উপলব্ধ হলে স্থানের নাম খুঁজে দেখা হয়।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Visit monitoring tracks places you visit. Significant location changes provides a trail between visits. Location names are looked up when available."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El monitoreo de visitas rastrea los lugares que visitas. Los cambios significativos de ubicación proporcionan un rastro entre visitas. Los nombres de lugares se buscan cuando están disponibles."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le suivi des visites enregistre les lieux que vous visitez. Les changements significatifs de position tracent un parcours entre les visites. Les noms de lieux sont recherchés lorsqu'ils sont disponibles."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "विज़िट निगरानी आपके द्वारा देखे गए स्थानों को ट्रैक करती है। उल्लेखनीय स्थान परिवर्तन विज़िट के बीच एक ट्रेल प्रदान करते हैं। उपलब्ध होने पर स्थान के नाम खोजे जाते हैं।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "訪問モニタリングは訪れた場所を記録します。大幅な位置変化は訪問間の軌跡を示します。可能な場合は地名を検索します。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O monitoramento de visitas rastreia os lugares que você visita. Mudanças significativas de localização fornecem um rastro entre visitas. Os nomes dos locais são pesquisados quando disponíveis."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Мониторинг посещений отслеживает места, которые вы посещаете. Значительные изменения местоположения создают след между посещениями. Названия мест ищутся, когда доступны."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "访问监测跟踪您访问的地点。重大位置变化提供访问间的足迹。可用时会查找地点名称。"
          }
        }
      }
    },
