    "All data stored locally. Never uploaded to any server.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All data stored locally. Never uploaded to any server."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جميع البيانات مخزنة محلياً. لم يتم تحميلها على أي خادم."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সমস্ত ডেটা স্থানীয়ভাবে সংরক্ষিত। কখনও কোনো সার্ভারে আপলোড করা হয় না।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos os dados armazenados localmente. Nunca enviados para nenhum servidor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все данные хранятся локально. Никогда не загружаются на серверы."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのデータはローカルに保存。サーバーにアップロードされることはありません。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toutes les données sont stockées localement. Jamais téléchargées sur un serveur."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos los datos se almacenan localmente. Nunca se carga a ningún servidor."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सभी डेटा स्थानीय रूप से संग्रहीत। कभी भी किसी सर्वर पर अपलोड नहीं किया गया।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有数据本地存储。从不上传到任何服务器。"
          }
        }
      }
    },
