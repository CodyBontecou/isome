    "\"ALWAYS\" ENABLES BACKGROUND TRACKING" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"دائماً\" يفعل التتبع في الخلفية"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"সর্বদা\" পটভূমিতে ট্র্যাকিং সক্ষম করে"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"ALWAYS\" ENABLES BACKGROUND TRACKING"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"SIEMPRE\" HABILITA EL SEGUIMIENTO EN SEGUNDO PLANO"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« TOUJOURS » ACTIVE LE SUIVI EN ARRIÈRE-PLAN"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"हमेशा\" बैकग्राउंड ट्रैकिंग सक्षम करता है"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「常に許可」がバックグラウンドトラッキングを有効化"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"SEMPRE\" ATIVA O RASTREAMENTO EM SEGUNDO PLANO"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«ВСЕГДА» ВКЛЮЧАЕТ ФОНОВОЕ ОТСЛЕЖИВАНИЕ"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"始终\"启用后台跟踪"
          }
        }
      }
    },
    "\"Always\" enables background tracking and automatic visit detection." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"دائماً\" يفعل التتبع في الخلفية والكشف التلقائي عن الزيارات."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"সর্বদা\" পটভূমিতে ট্র্যাকিং এবং স্বয়ংক্রিয় পরিদর্শন সনাক্তকরণ সক্ষম করে।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Always\" enables background tracking and automatic visit detection."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Siempre\" habilita el seguimiento en segundo plano y la detección automática de visitas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« Toujours » active le suivi en arrière-plan et la détection automatique des visites."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"हमेशा\" बैकग्राउंड ट्रैकिंग और स्वचालित विज़िट पहचान सक्षम करता है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「常に許可」でバックグラウンドトラッキングと自動訪問検出が有効になります。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Sempre\" ativa o rastreamento em segundo plano e a detecção automática de visitas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Всегда» включает фоновое отслеживание и автоматическое определение посещений."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"始终\"启用后台跟踪和自动访问检测。"
          }
        }
      }
    },
