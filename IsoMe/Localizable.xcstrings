            "value": "ترقية إلى \"السماح دائماً\" حتى يستمر الكشف عن الزيارات عند إغلاق التطبيق."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "\"সর্বদা অনুমতি দিন\" এ আপগ্রেড করুন যাতে অ্যাপ বন্ধ হলে পরিদর্শন সনাক্তকরণ চলতে থাকে।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Atualize para \"Sempre Permitir\" para que a detecção de visitas continue quando o aplicativo for fechado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обновитесь до «Всегда разрешать», чтобы определение посещений продолжалось при закрытом приложении."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「常に許可」にアップグレードして、アプリを閉じても訪問検出を続行。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Passer à « Toujours autoriser » pour que la détection des visites continue quand l'app est fermée."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualice a \"Permitir siempre\" para que la detección de visitas continúe cuando la app esté cerrada."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "\"हमेशा अनुमति दें\" में अपग्रेड करें ताकि ऐप बंद होने पर भी विज़िट पहचान जारी रहे।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "升级到\"始终允许\"以便在应用关闭时继续检测访问。"
          }
        }
      }
    },
