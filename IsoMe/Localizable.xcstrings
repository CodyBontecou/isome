    "Start by choosing \"Allow While Using App\" in the system prompt." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ابدأ باختيار \"السماح أثناء استخدام التطبيق\" في نافذة النظام."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "সিস্টেম প্রম্পটে \"অ্যাপ ব্যবহারের সময় অনুমতি দিন\" চয়ন করে শুরু করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start by choosing \"Allow While Using App\" in the system prompt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comience eligiendo \"Permitir mientras se usa la app\" en el aviso del sistema."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Commencez par choisir « Autoriser pendant l'utilisation de l'app » dans le système d'invite."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सिस्टम प्रॉम्प्ट में \"ऐप उपयोग करते समय अनुमति दें\" चुनकर शुरू करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "システムプロンプトで「Appの使用中のみ許可」を選択してください。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comece escolhendo \"Permitir Enquanto Usa o Aplicativo\" no prompt do sistema."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Начните с выбора «Разрешить при использовании приложения» в системном запросе."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "首先在系统提示中选择\"使用App时允许\"。"
          }
        }
      }
    },
    "Start now, or fine-tune tracking behavior later in Settings." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ابدأ الآن أو ضبط سلوك التتبع لاحقاً في Settings."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এখনই শুরু করুন, বা পরে Settings এ ট্র্যাকিং আচরণ সূক্ষ্মভাবে সামঞ্জস্য করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start now, or fine-tune tracking behavior later in Settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comienza ahora o ajusta el comportamiento de seguimiento más tarde en Configuración."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Commencez maintenant ou affinez le comportement du suivi plus tard dans les Réglages."
          }
        },
        "hi" : {
          "stringUnit" : {
