    "Location points will appear here as they're tracked.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Location points will appear here as they're tracked."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستظهر نقاط الموقع هنا عند تتبعها."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ট্র্যাক করার সাথে সাথে অবস্থান পয়েন্টগুলি এখানে উপস্থিত হবে।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os pontos de localização aparecerão aqui conforme forem rastreados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Точки местоположения будут отображаться здесь по мере отслеживания."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "位置情報ポイントはトラッキング時にここに表示されます。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les points de localisation apparaîtront ici au fur et à mesure du suivi."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los puntos de ubicación aparecerán aquí a medida que se registren."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थान बिंदु यहां दिखाई देंगे जैसे-जैसे उन्हें ट्रैक किया जाता है।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "位置点将在跟踪时出现在此处。"
          }
        }
      }
    },
