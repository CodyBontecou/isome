    "Exports will use the share sheet instead of saving directly to a folder.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Exports will use the share sheet instead of saving directly to a folder."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم استخدام ورقة المشاركة بدلاً من الحفظ مباشرة في مجلد."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "রপ্তানিগুলি ফোল্ডারে সরাসরি সংরক্ষণ করার পরিবর্তে শেয়ার শীট ব্যবহার করবে।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As exportações usarão a folha de compartilhamento em vez de salvar diretamente em uma pasta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Экспорт будет использовать меню общего доступа вместо прямого сохранения в папку."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エクスポートはフォルダに直接保存する代わりに共有シートを使用します。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les exports utiliseront le menu de partage au lieu de sauvegarder directement dans un dossier."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las exportaciones usarán la hoja de compartir en lugar de guardar directamente en una carpeta."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "निर्यात साझा शीट का उपयोग करेंगे, सीधे फ़ोल्डर में सहेजने के बजाय।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导出将使用共享表，而不是直接保存到文件夹。"
          }
        }
      }
    },
