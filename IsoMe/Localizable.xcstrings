    "High battery usage. Records your exact path between visits.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "High battery usage. Records your exact path between visits."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استهلاك بطارية عالي. يسجل المسار الدقيق بين الزيارات."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "উচ্চ ব্যাটারি ব্যবহার। পরিদর্শনগুলির মধ্যে আপনার সঠিক পথ রেকর্ড করে।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Alto uso de bateria. Registra seu caminho exato entre visitas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое энергопотребление. Записывает ваш точный маршрут между посещениями."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "高いバッテリー使用。訪問間の正確な経路を記録します。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Consommation élevée de batterie. Enregistre votre trajet exact entre les visites."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Alto uso de batería. Registra tu ruta exacta entre visitas."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उच्च बैटरी उपयोग। विजिट के बीच आपके सटीक पथ को रिकॉर्ड करता है।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "高电池消耗。记录您访问间的精确路径。"
          }
        }
      }
    },
