        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一目でわかり、バッテリー効率的で、必要な時に詳細情報を表示。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lisible d'un coup d'œil, économe en batterie et détaillé quand vous en avez besoin."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "De un vistazo, consciente de la batería, y profundamente contextual cuando lo necesites."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक नजर में देखने योग्य, बैटरी-जागरूक, और जब आपको इसकी आवश्यकता हो तो गहराई से संदर्भपूर्ण।"
          }
