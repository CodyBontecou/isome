    "Glanceable, battery-aware, and deeply contextual when you need it.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Glanceable, battery-aware, and deeply contextual when you need it."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سهل الاستخدام وموفر للبطارية وسياقي عميق عند الحاجة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এক নজরে দেখা যায়, ব্যাটারি-সচেতন এবং যখন প্রয়োজন গভীরভাবে প্রাসঙ্গিক।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Visível à primeira vista, eficiente em bateria e profundamente contextual quando você precisa."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Быстрый обзор, уважение к батарее и детальный контекст, когда нужно."
