    "Spotted needs access to your location to record the places you visit throughout the day." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحتاج Spotted إلى الوصول إلى موقعك لتسجيل الأماكن التي تزورها طوال اليوم."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spotted আপনার দিন জুড়ে যে স্থানগুলি পরিদর্শন করেন তা রেকর্ড করতে আপনার অবস্থান অ্যাক্সেসের প্রয়োজন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spotted needs access to your location to record the places you visit throughout the day."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spotted necesita acceso a tu ubicación para registrar los lugares que visitas a lo largo del día."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spotted a besoin d'accéder à votre localisation pour enregistrer les lieux visités tout au long de la journée."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spotted को आपके द्वारा पूरे दिन देखे गए स्थानों को रिकॉर्ड करने के लिए आपकी स्थिति तक पहुंच की आवश्यकता है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spottedが1日を通じて訪問した場所を記録するには位置情報へのアクセスが必要です。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spotted precisa de acesso à sua localização para registrar os locais que você visita ao longo do dia."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spotted требуется доступ к вашему местоположению, чтобы записывать места посещений в течение дня."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spotted需要访问您的位置以记录您全天访问的地点。"
          }
        }
      }
    },
