    "You've used your 10 hours of free tracking. Unlock unlimited tracking with a one-time purchase." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد استخدمت 10 ساعات من التتبع المجاني. فتح التتبع غير المحدود برشاء لمرة واحدة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনি ১০ ঘন্টার বিনামূল্যে ট্র্যাকিং ব্যবহার করেছেন। একবার ক্রয়ের মাধ্যমে সীমাহীন ট্র্যাকিং আনলক করুন।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You've used your 10 hours of free tracking. Unlock unlimited tracking with a one-time purchase."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Has utilizado tus 10 horas de seguimiento gratuito. Desbloquea el seguimiento ilimitado con una compra única."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez utilisé vos 10 heures de suivi gratuit. Déverrouillez le suivi illimité avec un achat unique."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपने अपने 10 घंटे की मुक्त ट्रैकिंग का उपयोग कर लिया है। एक बार की खरीद के साथ अनंत ट्रैकिंग को अनलॉक करें।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
