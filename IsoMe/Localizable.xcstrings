    "This visit will be permanently deleted." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيتم حذف هذه الزيارة نهائياً."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই পরিদর্শনটি স্থায়ীভাবে মুছে ফেলা হবে।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This visit will be permanently deleted."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta visita será eliminada permanentemente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette visite sera supprimée définitivement."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह विजिट स्थायी रूप से हटा दिया जाएगा।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
