    "A calm, private timeline of where your day takes you — always on-device and in your control.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A calm, private timeline of where your day takes you — always on-device and in your control."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "خط زمني هادئ وخاص لحيث يأخذك يومك — دائماً على الجهاز وتحت سيطرتك."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার দিন আপনাকে কোথায় নিয়ে যায় তার একটি শান্ত, ব্যক্তিগত সময়রেখা — সর্বদা ডিভাইসে এবং আপনার নিয়ন্ত্রণে।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma linha do tempo calma e privada de onde seu dia o leva — sempre no dispositivo e sob seu controle."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Спокойная, приватная лента ваших перемещений в течение дня — всегда на устройстве и под вашим контролем."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたの1日の行き先の静かでプライベートなタイムライン — 常にデバイス上であなたの管理下にあります。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une chronologie calme et privée de vos déplacements quotidiens — toujours sur votre appareil et sous votre contrôle."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una línea de tiempo tranquila y privada de adónde te lleva tu día — siempre en tu dispositivo y bajo tu control."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके दिन की एक शांत, निजी समयरेखा — हमेशा आपके डिवाइस पर और आपके नियंत्रण में।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一个平静、私密的日程时间线，记录您今天去过的地方——始终在您的设备上，完全由您掌控。"
          }
        }
      }
    },
