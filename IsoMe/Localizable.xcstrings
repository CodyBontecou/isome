          "stringUnit" : {
            "state" : "translated",
            "value" : "Это посещение будет навсегда удалено."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此访问将被永久删除。"
          }
        }
      }
    },
    "This will permanently delete all visit data and location points. This action cannot be undone." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى حذف جميع بيانات الزيارات ونقاط الموقع نهائياً. لا يمكن التراجع عن هذا الإجراء."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এটি সমস্ত পরিদর্শন ডেটা এবং অবস্থান পয়েন্ট স্থায়ীভাবে মুছে ফেলবে। এই পদক্ষেপটি পূর্ববত করা যায় না।"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will permanently delete all visit data and location points. This action cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará permanentemente todos los datos de visita y puntos de ubicación. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera définitivement toutes les données de visite et les points de localisation. Cette action ne peut pas être annulée."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह सभी विजिट डेटा और स्थान बिंदुओं को स्थायी रूप से हटा देगा। इस कार्रवाई को पूर्ववत नहीं किया जा सकता है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これによってすべての訪問データと位置情報ポイントが永遠に削除されます。この操作は元に戻せません。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso excluirá permanentemente todos os dados de visita e pontos de localização. Esta ação não pode ser desfeita."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это навсегда удалит все данные посещений и точки местоположения. Это действие нельзя отменить."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将永久删除所有访问数据和位置点。此操作无法撤销。"
          }
        }
      }
