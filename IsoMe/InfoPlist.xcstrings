    "NSLocationAlwaysAndWhenInUseUsageDescription": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Spotted uses your location to automatically detect places you visit and record your path throughout the day. Always access enables background visit detection."
          }
        },
