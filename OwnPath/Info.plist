<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>NSSupportsLiveActivities</key>
    <true/>
    
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>ownpath</string>
            </array>
            <key>CFBundleURLName</key>
            <string>com.bontecou.OwnPath</string>
        </dict>
    </array>
    
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>OwnPath needs always-on location access to automatically record the places you visit throughout the day, even when the app is in the background. This enables visit detection and travel tracking.</string>

    <key>NSLocationWhenInUseUsageDescription</key>
    <string>OwnPath needs location access to show your current location and record visits when the app is open.</string>

    <key>UIBackgroundModes</key>
    <array>
        <string>location</string>
    </array>

    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>com.bontecou.OwnPath.refresh</string>
    </array>
</dict>
</plist>
