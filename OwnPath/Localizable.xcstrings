    "You've used your 10 hours of free tracking. Unlock unlimited tracking with a one-time purchase.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You've used your 10 hours of free tracking. Unlock unlimited tracking with a one-time purchase."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لقد استخدمت 10 ساعات من التتبع المجاني. فتح التتبع غير المحدود برشاء لمرة واحدة."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনি ১০ ঘন্টার বিনামূল্যে ট্র্যাকিং ব্যবহার করেছেন। একবার ক্রয়ের মাধ্যমে সীমাহীন ট্র্যাকিং আনলক করুন।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você usou suas 10 horas de rastreamento gratuito. Desbloqueie o rastreamento ilimitado com uma compra única."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы использовали 10 часов бесплатного отслеживания. Разблокируйте неограниченное отслеживание с помощью разовой покупки."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "10時間の無料トラッキングを使用しました。1回のみの購入で無制限トラッキングをアンロック。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez utilisé vos 10 heures de suivi gratuit. Déverrouillez le suivi illimité avec un achat unique."
          }
        }
      }
    },
    "Unlimited tracking forever": {
      "localizations": {
