    "OwnPath needs access to your location to record the places you visit throughout the day.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "OwnPath needs access to your location to record the places you visit throughout the day."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتاج OwnPath إلى الوصول إلى موقعك لتسجيل الأماكن التي تزورها طوال اليوم."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "OwnPath আপনার দিন জুড়ে যে স্থানগুলি পরিদর্শন করেন তা রেকর্ড করতে আপনার অবস্থান অ্যাক্সেসের প্রয়োজন।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "OwnPath precisa de acesso à sua localização para registrar os locais que você visita ao longo do dia."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "OwnPath требуется доступ к вашему местоположению, чтобы записывать места посещений в течение дня."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "OwnPathが1日を通じて訪問した場所を記録するには位置情報へのアクセスが必要です。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "OwnPath a besoin d'accéder à votre localisation pour enregistrer les lieux visités tout au long de la journée."
          }
        }
      }
    },
