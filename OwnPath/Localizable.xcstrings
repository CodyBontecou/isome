    "Upgrade to \"Always Allow\" so visit detection continues when the app is closed.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Upgrade to \"Always Allow\" so visit detection continues when the app is closed."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ترقية إلى \"السماح دائماً\" حتى يستمر الكشف عن الزيارات عند إغلاق التطبيق."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "\"সর্বদা অনুমতি দিন\" এ আপগ্রেড করুন যাতে অ্যাপ বন্ধ হলে পরিদর্শন সনাক্তকরণ চলতে থাকে।"
          }
        },
        "pt-BR": {
          "stringUnit": {
