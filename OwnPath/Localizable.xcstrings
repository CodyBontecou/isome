    "Visit monitoring tracks places you visit. Significant location changes provides a trail between visits.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Visit monitoring tracks places you visit. Significant location changes provides a trail between visits."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتتبع مراقبة الزيارات الأماكن التي تزورها. تتبع التغييرات المهمة في الموقع يوفر مسار بين الزيارات."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "পরিদর্শন মনিটরিং আপনি যে স্থানগুলি পরিদর্শন করেন তা ট্র্যাক করে। উল্লেখযোগ্য অবস্থান পরিবর্তন পরিদর্শনগুলির মধ্যে একটি ট্রেইল সরবরাহ করে।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O monitoramento de visitas rastreia os locais que você visita. Mudanças significativas de localização fornecem um rastro entre visitas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мониторинг посещений отслеживает места, которые вы посещаете. Значительные изменения местоположения отслеживают маршрут между посещениями."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "訪問監視は訪問した場所を追跡します。重要な位置変更は訪問間の履跡を提供します。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La surveillance des visites enregistre les lieux visités. Les changements de localisation importants fournissent une trace entre les visites."
          }
        }
      }
    },
