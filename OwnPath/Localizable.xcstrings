    "High battery usage. Records your exact path between visits.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "High battery usage. Records your exact path between visits."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استهلاك بطارية عالي. يسجل المسار الدقيق بين الزيارات."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "উচ্চ ব্যাটারি ব্যবহার। পরিদর্শনগুলির মধ্যে আপনার সঠিক পথ রেকর্ড করে।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Alto uso de bateria. Registra seu caminho exato entre visitas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Высокое энергопотребление. Записывает ваш точный маршрут между посещениями."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "高いバッテリー使用。訪問間の正確な経路を記録します。"
          }
        },
        "fr": {
