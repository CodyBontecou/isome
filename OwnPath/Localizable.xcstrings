    "Free for your first 10 hours. One-time purchase for unlimited use.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Free for your first 10 hours. One-time purchase for unlimited use."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مجاني لأول 10 ساعات. شراء لمرة واحدة للاستخدام غير المحدود."
          }
