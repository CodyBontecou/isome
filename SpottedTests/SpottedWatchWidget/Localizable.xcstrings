    "View your tracking status and today's stats.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "View your tracking status and today's stats."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اعرض حالة التتبع وإحصائيات اليوم."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার ট্র্যাকিং স্থিতি এবং আজকের পরিসংখ্যান দেখুন।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja seu status de rastreamento e as estatísticas de hoje."
