        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपनी ट्रैकिंग स्थिति और आज के आंकड़े देखें।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "查看您的跟踪状态和今天的统计数据。"
